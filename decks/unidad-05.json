{
  "unit": "Unidad 5 — Ausencia de artículo (артикль или ∅)",
  "blocks": [
    {
      "title": "После ser/hacerse: профессия/религия/нация/идеология → ∅",
      "mode": "cloze",
      "cards": [
        { "front": "Soy ___ estudiante.", "back": "∅", "note": "профессия после ser → ∅", "translation": "Я студент." },
        { "front": "Chantal es ___ francesa.", "back": "∅", "note": "национальность → ∅", "translation": "Шанталь — француженка." },
        { "front": "Es ___ abogada.", "back": "∅", "note": "профессия → ∅", "translation": "Она адвокат." },
        { "front": "Lenin y Stalin eran ___ comunistas.", "back": "∅", "note": "идеология → ∅", "translation": "Ленин и Сталин были коммунистами." },
        { "front": "Alberto se ha hecho ___ budista.", "back": "∅", "note": "религия после hacerse → ∅", "translation": "Альберто стал буддистом." },
        { "front": "Tomás se ha hecho ___ musulmán.", "back": "∅", "note": "религия → ∅", "translation": "Томас стал мусульманином." },
        { "front": "Los tíos de Andrea son ___ protestantes.", "back": "∅", "note": "религия → ∅", "translation": "Дядя и тётя Андреа — протестанты." },
        { "front": "Alberto y Lola son ___ socialistas.", "back": "∅", "note": "идеология → ∅", "translation": "Альберто и Лола — социалисты." },
        { "front": "No, soy ___ vegetariano.", "back": "∅", "note": "после ser → ∅", "translation": "Нет, я вегетарианец." },
        { "front": "Ernesto es ___ músico.", "back": "∅", "note": "профессия → ∅", "translation": "Эрнесто — музыкант." },
        { "front": "Carolina es ___ vendedora.", "back": "∅", "note": "профессия → ∅", "translation": "Каролина — продавщица." },
        { "front": "La hermana de Rosa es ___ profesora de español.", "back": "∅", "note": "профессия → ∅", "translation": "Сестра Розы — преподавательница испанского." },
        { "front": "Almodóvar es ___ director de cine.", "back": "∅", "note": "профессия → ∅", "translation": "Альмодовар — кинорежиссёр." }
      ]
    },
    {
      "title": "Прямое дополнение = класс вещей (не конкретный предмет) → ∅",
      "mode": "cloze",
      "cards": [
        { "front": "Lola colecciona ___ sellos.", "back": "∅", "note": "вещи вообще → ∅", "translation": "Лола коллекционирует марки." },
        { "front": "Escribe ___ novelas.", "back": "∅", "note": "класс → ∅", "translation": "Он пишет романы." },
        { "front": "Están buscando ___ piso.", "back": "∅", "note": "не конкретный → ∅", "translation": "Они ищут квартиру." },
        { "front": "¿Tienes ___ teléfono?", "back": "∅", "note": "вообще → ∅", "translation": "У тебя есть телефон?" },
        { "front": "No tengo ___ coche.", "back": "∅", "note": "вообще → ∅", "translation": "У меня нет машины." },
        { "front": "Siempre bebemos ___ agua en las comidas.", "back": "∅", "note": "неисчисляемое → ∅", "translation": "Мы всегда пьём воду за едой." },
        { "front": "Ernesto no come ___ carne.", "back": "∅", "note": "класс → ∅", "translation": "Эрнесто не ест мясо." },
        { "front": "¿Hay ___ pan?", "back": "∅", "note": "вообще → ∅", "translation": "Хлеб есть?" },
        { "front": "Tomás canta ___ flamenco.", "back": "∅", "note": "вообще → ∅", "translation": "Томас поёт фламенко." },
        { "front": "Antonio vende ___ coches.", "back": "∅", "note": "класс → ∅", "translation": "Антонио продаёт машины." },
        { "front": "Necesito ___ gafas.", "back": "∅", "note": "вообще → ∅", "translation": "Мне нужны очки." },
        { "front": "¿Tienes ___ hermanos?", "back": "∅", "note": "вообще → ∅", "translation": "У тебя есть братья/сёстры?" },
        { "front": "Escribe ___ canciones.", "back": "∅", "note": "класс → ∅", "translation": "Он пишет песни." },
        { "front": "Vende ___ enciclopedias.", "back": "∅", "note": "класс → ∅", "translation": "Она продаёт энциклопедии." },
        { "front": "¿Comes ___ carne?", "back": "∅", "note": "класс → ∅", "translation": "Ты ешь мясо?" },
        { "front": "¿Quieres ___ queso?", "back": "∅", "note": "вещество вообще → ∅", "translation": "Хочешь сыра?" }
      ]
    },
    {
      "title": "PERO: есть прилагательное → артикль возвращается",
      "mode": "cloze",
      "cards": [
        { "front": "Chantal es ___ francesa muy simpática.", "back": "una", "note": "+ прилаг. → una", "translation": "Шанталь — очень милая француженка." },
        { "front": "Es ___ médico extraordinario.", "back": "un", "note": "+ прилаг. → un", "translation": "Он выдающийся врач." },
        { "front": "Es ___ profesora muy seria.", "back": "una", "note": "+ прилаг. → una", "translation": "Она очень серьёзная преподавательница." },
        { "front": "Es ___ actriz muy famosa.", "back": "una", "note": "+ прилаг. → una", "translation": "Она очень известная актриса." },
        { "front": "Tengo ___ sellos muy raros.", "back": "unos", "note": "+ прилаг. → unos", "translation": "У меня есть очень редкие марки." },
        { "front": "Aquí hacen ___ pan buenísimo.", "back": "un", "note": "+ прилаг. → un", "translation": "Здесь пекут отличный хлеб." },
        { "front": "Necesito ___ gafas especiales.", "back": "unas", "note": "+ прилаг. → unas", "translation": "Мне нужны специальные очки." },
        { "front": "Hoy lleva ___ corbata muy original.", "back": "una", "note": "+ прилаг. → una", "translation": "Сегодня на нём очень оригинальный галстук." },
        { "front": "No, es ___ queso muy fuerte.", "back": "un", "note": "+ прилаг. → un", "translation": "Нет, это очень острый сыр." }
      ]
    },
    {
      "title": "PERO: идентификация по профессии (¿Quién es?) → артикль",
      "mode": "cloze",
      "cards": [
        { "front": "¿Quiénes son las Hijas del Sol? — Son ___ cantantes.", "back": "unas", "note": "идентификация → unas", "translation": "Кто такие «Дочери Солнца»? — Они певицы." },
        { "front": "¿Quién es Almodóvar? — Es ___ director de cine.", "back": "un", "note": "идентификация → un", "translation": "Кто такой Альмодовар? — Он кинорежиссёр." },
        { "front": "¿Quién es Luis Miguel? — Es ___ cantante.", "back": "un", "note": "идентификация → un", "translation": "Кто такой Луис Мигель? — Он певец." },
        { "front": "¿Quién es Vargas Llosa? — Es ___ escritor.", "back": "un", "note": "идентификация → un", "translation": "Кто такой Варгас Льоса? — Он писатель." }
      ]
    },
    {
      "title": "PERO: количество (=1 или несколько) → артикль",
      "mode": "cloze",
      "cards": [
        { "front": "La novia ha publicado ___ novela.", "back": "una", "note": "= одна → una", "translation": "Невеста опубликовала (один) роман." },
        { "front": "Me han regalado ___ sellos.", "back": "unos", "note": "= несколько → unos", "translation": "Мне подарили несколько марок." },
        { "front": "Hoy ha vendido ___ coche.", "back": "un", "note": "= один → un", "translation": "Сегодня он продал (одну) машину." },
        { "front": "Tengo ___ hermana.", "back": "una", "note": "= одна → una", "translation": "У меня есть (одна) сестра." },
        { "front": "Alberto tiene ___ apartamento en Benidorm.", "back": "un", "note": "= один → un", "translation": "У Альберто есть квартира в Бенидорме." },
        { "front": "Solo ___ taza al día.", "back": "una", "note": "= одна → una", "translation": "Только одна чашка в день." }
      ]
    }
  ]
}
